# Copy to .env and fill in for local/docker use.

SECRET_KEY=change-me-to-a-random-value
DATABASE_URL=sqlite:////app/instance/parts.db

# Shown as the browser tab title and nav-bar brand in the web UI.
SITE_TITLE=PMS

# Set to "true" once this app is served over HTTPS (e.g. behind a reverse
# proxy). Leave false for a plain-HTTP LAN deployment, or the browser will
# silently drop the session cookie on every request.
SESSION_COOKIE_SECURE=false

# Bootstrap value only: on first run this is auto-imported as one real,
# ownerless ApiKey row (see /admin/api-keys) so there's a working key before
# anyone's created a proper per-person one. The MCP server itself holds no
# credential — each person should connect with their own key created from
# /admin/api-keys (or `flask create-api-key --username <person>`), not this
# value. Manage/revoke keys there afterward instead of editing this file.
API_TOKEN=change-me-to-a-random-token

# Deprecated — only read once, on upgrade, to deactivate the old shared MCP
# system account (every key now needs a real owner instead). Safe to remove
# from .env once you've confirmed that account shows as inactive in
# /admin/users; harmless to leave.
MCP_USER_USERNAME=mcp

# Google Sheets sync
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google_service_account.json
SYNC_INTERVAL_MINUTES=20
SHEETS_SYNC_ENABLED=true

# Used by the MCP server container to reach the web container's internal API.
PMS_API_BASE_URL=http://web:5000

# What the MCP server binds to inside its own container. Shown (along with the
# above) on the admin MCP-info page — the web app doesn't use these itself.
MCP_HOST=0.0.0.0
MCP_PORT=8000
