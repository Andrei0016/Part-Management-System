# Copy to .env and fill in for local/docker use.

SECRET_KEY=change-me-to-a-random-value
DATABASE_URL=sqlite:////app/instance/parts.db

# Shown as the browser tab title and nav-bar brand in the web UI.
SITE_TITLE=PMS

# Token the MCP server must send as "Authorization: Bearer <token>" to use /api/*.
API_TOKEN=change-me-to-a-random-token

# System account name attributed to all MCP-driven changes in the activity log.
MCP_USER_USERNAME=mcp
MCP_USER_FULL_NAME=Claude (MCP)

# Google Sheets sync
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google_service_account.json
SYNC_INTERVAL_MINUTES=20
SHEETS_SYNC_ENABLED=true

# Used by the MCP server container to reach the web container's internal API.
PMS_API_BASE_URL=http://web:5000

# What the MCP server binds to inside its own container. Shown (along with the
# above) on the admin MCP-info page — the web app doesn't use these itself.
MCP_HOST=0.0.0.0
MCP_PORT=8000
